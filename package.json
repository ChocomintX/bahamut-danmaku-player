{
  "name": "bahamut-danmaku-player",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop app for loading Bahamut Anime danmaku and syncing it with local videos.",
  "author": "ChocomintX",
  "homepage": "https://github.com/ChocomintX/bahamut-danmaku-player",
  "repository": {
    "type": "git",
    "url": "git@github.com:ChocomintX/bahamut-danmaku-player.git"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "tsc -b && vite build",
    "preview:app": "npm run build && electron .",
    "package:dir": "npm run build && electron-builder --dir",
    "package:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "opencc-js": "^1.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.chocomint.bahamutdanmakuplayer",
    "productName": "动画疯弹幕播放器",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    }
  }
}
